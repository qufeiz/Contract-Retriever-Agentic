# Copy to .env (gitignored) and fill in real values. NEVER commit real values.

# Anthropic — the Claude Agent SDK powers the retrieval agent.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Default agent model (capable + cost-reasonable). claude-haiku-4-5 is used for cheap sub-steps.
AGENT_MODEL=claude-sonnet-4-6
# Hard ceiling on agent turns (runaway-cost guard). Optional.
AGENT_MAX_TURNS=40

# The Next.js /api/ask route proxies to the Python FastAPI agent backend at this URL.
AGENT_BACKEND_URL=http://127.0.0.1:8000

# The mock data is anchored to this date (e.g. "38 contracts expire within 90 days").
# The agent is instructed to use this as asOfDate so date-relative answers are deterministic.
ASSISTANT_TODAY=2026-06-09
